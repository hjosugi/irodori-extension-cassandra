{
  "schemaVersion": 1,
  "extensionId": "irodori.cassandra",
  "visibility": "public",
  "version": "0.1.1",
  "connector": {
    "id": "cassandra.connector",
    "engine": "cassandra",
    "label": "Cassandra",
    "aliases": [
      "cassandra",
      "Cassandra"
    ],
    "defaultPort": 9042,
    "wire": "cassandra",
    "module": "cassandra.driver",
    "features": [
      "metadata",
      "streaming"
    ]
  },
  "connection": {
    "endpoint": {
      "modes": [
        "hostPort",
        "connectionString"
      ],
      "defaultPort": 9042,
      "fields": [
        {
          "id": "host",
          "label": "Host",
          "type": "string",
          "profileField": "host",
          "required": true
        },
        {
          "id": "port",
          "label": "Port",
          "type": "number",
          "profileField": "port",
          "default": 9042
        },
        {
          "id": "database",
          "label": "Database",
          "type": "string",
          "profileField": "database"
        }
      ]
    },
    "authMethods": [
      "none",
      "connectionString",
      "userPassword",
      "saslPlain",
      "saslScram",
      "clientCertificate",
      "kerberos",
      "awsDefaultCredentialsChain",
      "awsSigV4",
      "awsProfile",
      "webIdentity",
      "awsAssumeRole",
      "customDriverOptions"
    ],
    "tls": "optional",
    "transports": "default",
    "optionNamespaces": [
      "cassandra"
    ],
    "customDriverOptions": true
  },
  "runtime": {
    "driverLinked": true
  },
  "source": {
    "knowledgeEngineStatus": "wired",
    "adapter": "db/cassandra.rs"
  }
}
